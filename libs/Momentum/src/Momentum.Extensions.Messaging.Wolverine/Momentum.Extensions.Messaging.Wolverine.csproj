<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <!-- Disable configuration binding source generator - WolverineOptions has complex types
             (Endpoint, MemberInfo) that the source generator cannot handle (SYSLIB1100/1101) -->
        <EnableConfigurationBindingGenerator>false</EnableConfigurationBindingGenerator>
    </PropertyGroup>

    <Import Project="Momentum.Extensions.Messaging.Wolverine.props"/>

    <!--#if (!LIBS_INCLUDES_WOLVERINE) -->
    <PropertyGroup>
        <IsPackable>true</IsPackable>
        <PackageId>Momentum.Extensions.Messaging.Wolverine</PackageId>
        <PackageDescription>Wolverine messaging integration for Momentum platform providing production-ready
            CQRS message handling with PostgreSQL persistence, FluentValidation, and OpenTelemetry support.
        </PackageDescription>
        <PackageProjectUrl>
            https://github.com/vgmello/momentum/blob/main/libs/Momentum/src/Momentum.Extensions.Messaging.Wolverine/README.md
        </PackageProjectUrl>
    </PropertyGroup>

    <ItemGroup>
        <None Include="Momentum.Extensions.Messaging.Wolverine.props" Pack="true" PackagePath="build/"/>
    </ItemGroup>
    <!--#endif -->

    <ItemGroup>
        <FrameworkReference Include="Microsoft.AspNetCore.App"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Aspire.Npgsql"/>
        <PackageReference Include="CloudNative.CloudEvents.SystemTextJson"/>
        <PackageReference Include="FluentValidation.DependencyInjectionExtensions"/>
        <PackageReference Include="OpenTelemetry.Extensions.Hosting"/>
        <PackageReference Include="WolverineFx"/>
        <PackageReference Include="WolverineFx.Postgresql"/>
        <!--#if (LIBS_INCLUDES_WOLVERINE)
        <PackageReference Include="Momentum.Extensions.Messaging"/>
        #endif -->
    </ItemGroup>
    <!--#if (!LIBS_INCLUDES_WOLVERINE) -->
    <Import Project="../Momentum.Extensions/Momentum.Extensions.props"
            Condition="Exists('../Momentum.Extensions/Momentum.Extensions.props')"/>

    <ItemGroup>
        <ProjectReference Include="..\Momentum.Extensions.Messaging\Momentum.Extensions.Messaging.csproj"/>
    </ItemGroup>
    <!--#endif -->
</Project>
